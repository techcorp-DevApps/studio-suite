# ─────────────────────────────────────────────────────────────────────────────
# studio-suite — backend environment template
# Copy to backend/.env for local dev, or set these as service Variables on Railway.
# Names only: never commit real values. Required vars must be present or the app
# reports a clear error on first use (it still starts so health checks pass).
# ─────────────────────────────────────────────────────────────────────────────

# ---- Environment ----
# "production" disables dev-only conveniences; anything else enables them.
ENVIRONMENT=

# ---- Database (REQUIRED for the DB health probe) ----
# Canonical names only — no legacy aliases. Use the MongoDB Atlas/Railway driver
# connection string; percent-encode special characters in the username/password.
MONGODB_URI=
MONGODB_DB_NAME=

# ---- Database tuning (OPTIONAL — safe defaults applied when unset) ----
MONGODB_APP_NAME=
MONGODB_MAX_POOL_SIZE=
MONGODB_SERVER_SELECTION_TIMEOUT_MS=

# ---- CORS ----
# Comma-separated explicit origins (enables credentialed cross-site requests).
CORS_ORIGINS=
# Optional regex for ephemeral Railway preview hosts, e.g.
# ^https://web-[a-z0-9-]+\.up\.railway\.app$
CORS_ORIGIN_REGEX=

# ---- Cloudflare R2 (RESERVED — adapter implemented in a later task) ----
# Reserved by name only; no R2 client is wired in task 01.0.0.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_ORIGINALS=
R2_BUCKET_DERIVATIVES=
