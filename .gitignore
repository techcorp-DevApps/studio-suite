# ── studio-suite monorepo .gitignore ─────────────────────────────────────────

# Local orchestration + workflow scratch (never committed)
.orchestrator/
.automate-dev/
.claude/

# Environment files (never commit secrets) — keep the .env.example templates
.env
.env.*
*.env
!.env.example
!**/.env.example

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Node / web
node_modules/
.npm/
.eslintcache

# Build output
build/
dist/
*.tsbuildinfo

# Expo / EAS local artifacts (mobile is scaffolded in task 01.1.0)
.expo/
.expo-shared/
web-build/
*.jks
*.p8
*.p12
*.mobileprovision
*.orig.*

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS / editor cruft
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
